# LLM API（OpenAI 兼容接口，支持 Claude / DeepSeek / 通义等）
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# 服务端
PORT=3002
DATABASE_URL=./data/talk-to-god.db
CORS_ORIGIN=http://localhost:5180

# 登录 JWT 密钥（生产环境请改为随机长字符串）
JWT_SECRET=change-me-in-production

# 游客模式单用户最多可发送的消息条数
GUEST_MESSAGE_LIMIT=3

# 后台管理密钥（请求头 X-Admin-Key 或 Authorization: Bearer）
ADMIN_SECRET=change-me-admin-secret

# 腾讯云 COS（可选，用于头像等静态资源）
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=lhcos
COS_REGION=ap-guangzhou
